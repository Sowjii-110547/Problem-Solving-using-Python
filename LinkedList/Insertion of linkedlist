# insert front and end of a linkedlist.
class Node:
    def __init__(self,data):
        self.data=data
        self.next=None 
class LinkedList:
    def __init__(self):
        self.head=None 
    def insertend(self,data):
        newnode=Node(data)
        if self.head is None:
            self.head=newnode 
        else:
            temp=self.head 
            while temp.next!=None:
                temp=temp.next 
            temp.next=newnode
    def insertfront(self,data):
        newnode=Node(data)
        if self.head is None:
            self.head=newnode 
        else:
            newnode.next=self.head 
            self.head=newnode
    def display(self):
        temp=self.head 
        print("Linked list elements are: ")
        while temp!=None:
            print(temp.data,end=" ")
            temp=temp.next 
ob=LinkedList()
ob.insertend(10)
ob.insertend(20)
ob.insertend(30)
ob.insertfront(40)
ob.insertfront(50)
ob.display()

